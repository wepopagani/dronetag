# ─── Firebase web config (NEXT_PUBLIC_* gets bundled into the client) ────────
# Copy this file to `.env.local` and fill in the values from
# Firebase Console → Project settings → Your apps → SDK snippet (Config).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Region the Cloud Functions are deployed to (default: us-central1).
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# ─── App Check (PR-SEC-2 V-035) ──────────────────────────────────────────────
# Register a reCAPTCHA Enterprise key OR a reCAPTCHA v3 key. Init prefers
# Enterprise. Skip both in local dev; App Check init is silently disabled.
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Local-dev only: pre-shared debug token registered in the Firebase
# Console (App Check → Apps → debug). Lets local dev pass enforcement.
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# ─── Server-side (NOT bundled — keep secret) ─────────────────────────────────
# JSON of a Firebase service-account key. Required for:
#   • proxy.ts (admin route gate, V-029)
#   • /api/session (HttpOnly cookie verification)
#   • scripts/grant-admin.ts
# Generate via: Firebase Console → Project settings → Service accounts
#  → Generate new private key.
#
# Local dev (recommended): save the JSON file outside the repo and set PATH:
#   FIREBASE_SERVICE_ACCOUNT_PATH=/Users/you/keys/dronetag-e905d-admin.json
#
# Netlify / hosts without a filesystem: paste the whole JSON on one line:
#   FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Functions enforcement toggle. Set to "false" while in App Check
# MONITOR mode; flip to "true" once the dashboard is clean.
APP_CHECK_ENFORCE=true

# ─── PR-SEC-3 — CSP and host allowlists ──────────────────────────────────────
# Comma-separated list of hostnames in addition to Firebase Storage that
# may host PDFs / images referenced by the app (e.g. a corporate CDN).
# Hostnames only — no protocol, no path, no commas, no spaces.
NEXT_PUBLIC_TRUSTED_PDF_HOSTS=

# Same list, server-side. Mirrors the public list 1:1 so client and
# server reject the same hosts. Keep them in sync at deploy time.
TRUSTED_PDF_HOSTS=

# CSP enforce toggle. Default (unset / any value other than "true") ships
# the Content-Security-Policy-Report-Only header. Set to "true" once you
# have observed several days of clean traffic in the browser console.
CSP_ENFORCE=

# ─── Scripts only ────────────────────────────────────────────────────────────
# Used by scripts under ./scripts/* to authenticate as an existing user
# that already has the admin custom claim. Must NEVER be committed.
SEED_AUTH_EMAIL=
SEED_AUTH_PASSWORD=
